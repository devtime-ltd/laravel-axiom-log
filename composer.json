{
    "name": "devtime-ltd/laravel-axiom-log",
    "description": "Batched Monolog handler for Axiom in Laravel.",
    "keywords": ["laravel", "axiom", "logging", "monolog"],
    "license": "MIT",
    "authors": [
        {
            "name": "Alun Davey"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "DevtimeLtd\\LaravelAxiomLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DevtimeLtd\\LaravelAxiomLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
